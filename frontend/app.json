{
  "expo": {
    "name": "FIT AI",
    "slug": "fit-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Prendre des photos de tes repas et progressions",
        "NSPhotoLibraryUsageDescription": "Sélectionner photos de repas et transformations"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FAFAF8"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAFAF8"
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'app accède à tes photos pour analyser tes repas.",
          "cameraPermission": "L'app utilise la caméra pour photographier tes repas."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "L'app utilise la caméra pour photographier tes repas."
        }
      ],
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
