{
  "expo": {
    "name": "FIT AI",
    "slug": "fit-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Prendre des photos de tes repas et progressions",
        "NSPhotoLibraryUsageDescription": "Sélectionner photos de repas et transformations",
        "NSPhotoLibraryAddUsageDescription": "Enregistrer ta story de performance dans tes photos"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FAFAF8"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAFAF8"
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'app accède à tes photos pour analyser tes repas.",
          "cameraPermission": "L'app utilise la caméra pour photographier tes repas."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "L'app utilise la caméra pour photographier tes repas."
        }
      ],
      "expo-audio",
      "expo-asset",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "79f780f1-9e98-428e-9a0f-f977ff18df71"
      }
    },
    "owner": "global_ai_studio",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/79f780f1-9e98-428e-9a0f-f977ff18df71"
    }
  }
}
